
# В каждом окружении загружаются следующие файлы (последующий перекрывает предыдущий):
#
#  * .env                дефолтные значения, коммитится в репо
#  * .env.local          локальные переопределения, не коммитится
#  * .env.$APP_ENV       дефолты для конкретного окружения, коммитится
#  * .env.$APP_ENV.local локальные переопределения для окружения, не коммитится
#
# Переменные окружения операционной системы всегда побеждают .env файлы.
# НЕ ОПРЕДЕЛЯЙТЕ СЕКРЕТЫ ПРОДАКШНА В ЭТОМ ФАЙЛЕ.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
RABBITMQ_DSN=amqp://guest:guest@localhost:5672/%2f
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
POSTGRES_USER=sonanz
POSTGRES_PASSWORD=sonanz
POSTGRES_DB=sonanz
DATABASE_URL="postgresql://sonanz:sonanz@127.0.0.1:5432/sonanz?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

REDIS_URL=redis://localhost:6380

JWT_SECRET=

YOUTUBE_API_KEY=
ACOUSTID_API_KEY=

YT_DLP_BIN=yt-dlp
YT_DLP_DENO_BIN=deno
YT_DLP_COOKIES_FILE=
